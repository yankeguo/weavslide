<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  scroll-snap-type: y mandatory;
  background: #0f0f1a;
}

body {
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
               "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif;
  -webkit-font-smoothing: antialiased;
  color: #1a1a2e;
}

.page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  scroll-snap-align: start;
  padding: 24px;
}

.slide {
  width: 90vw;
  max-width: 1280px;
  aspect-ratio: 16 / 9;
  background: linear-gradient(135deg, #fafbff 0%, #f2f3fa 100%);
  border-radius: 12px;
  box-shadow:
    0 4px 40px rgba(102, 126, 234, .15),
    0 1px 3px rgba(0, 0, 0, .08);
  padding: 56px 64px 48px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  position: relative;
}

.slide::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 5px;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 50%, #e94560 100%);
  border-radius: 12px 12px 0 0;
}

.slide::after {
  content: "";
  position: absolute;
  top: -80px; right: -80px;
  width: 240px; height: 240px;
  background: radial-gradient(circle, rgba(102, 126, 234, .06) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.slide h1 {
  font-size: 2.4em;
  font-weight: 800;
  color: #16213e;
  margin-bottom: .35em;
  line-height: 1.25;
  letter-spacing: -.01em;
}

.slide h2 {
  font-size: 1.7em;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: .3em;
  line-height: 1.3;
}

.slide h3 {
  font-size: 1.35em;
  font-weight: 600;
  color: #0f3460;
  margin-bottom: .25em;
  line-height: 1.35;
}

.slide p {
  line-height: 1.7;
  margin-bottom: .5em;
}

.slide ul, .slide ol {
  padding-left: 1.4em;
  line-height: 1.8;
  margin-bottom: .4em;
}

.slide li {
  margin-bottom: .2em;
}

.slide li::marker {
  color: #667eea;
}

.slide strong {
  color: #e94560;
  font-weight: 700;
}

.slide em {
  color: #667eea;
  font-style: normal;
  font-weight: 500;
}

.slide a {
  color: #667eea;
  text-decoration: none;
  border-bottom: 1px solid rgba(102, 126, 234, .3);
}
.slide a:hover { color: #764ba2; }

.slide small {
  font-size: .75em;
  color: #888;
}

.slide blockquote {
  margin: .4em 0 .6em;
  padding: .4em 0 .4em 1em;
  border-left: 4px solid #667eea;
  color: #555;
  font-size: 1.05em;
  line-height: 1.6;
  background: linear-gradient(90deg, rgba(102, 126, 234, .05) 0%, transparent 100%);
  border-radius: 0 6px 6px 0;
}

.slide blockquote p { margin-bottom: 0; }

.slide code {
  font-family: "SF Mono", "Fira Code", "Cascadia Code", "JetBrains Mono",
               "Noto Sans Mono", monospace;
  font-size: .88em;
  font-variant-ligatures: none;
  background: rgba(102, 126, 234, .08);
  color: #e94560;
  padding: .15em .4em;
  border-radius: 4px;
}

.slide pre {
  background: #1a1a2e;
  color: #e2e8f0;
  padding: 18px 22px;
  border-radius: 10px;
  font-size: .82em;
  line-height: 1.55;
  overflow-x: auto;
  margin: .5em 0;
  font-variant-ligatures: none;
}

.slide pre code {
  background: transparent;
  color: inherit;
  padding: 0;
  font-size: inherit;
  border-radius: 0;
}

.slide hr {
  border: none;
  border-top: 1px solid rgba(102, 126, 234, .18);
  margin: .6em 0;
}

.slide table {
  width: 100%;
  border-collapse: collapse;
  margin: .5em 0;
  font-size: .88em;
}

.slide th, .slide td {
  border: 1px solid #d8dae8;
  padding: 8px 14px;
  text-align: left;
}

.slide th {
  background: linear-gradient(180deg, #eef0fa 0%, #e4e6f4 100%);
  font-weight: 700;
  color: #16213e;
  font-size: .92em;
}

.slide tr:nth-child(even) td {
  background: rgba(102, 126, 234, .03);
}

.slide img {
  max-width: 100%;
  max-height: 60vh;
  border-radius: 8px;
  display: block;
  margin: .5em auto;
}

.slide .mermaid {
  display: flex;
  justify-content: center;
  margin: .5em 0;
  font-family: system-ui, -apple-system, "Noto Sans SC", "PingFang SC", sans-serif;
}

.slide .mermaid svg {
  max-width: 100%;
  max-height: 55vh;
}

.pageno {
  position: absolute;
  bottom: 18px;
  right: 28px;
  font-size: .78em;
  font-variant-numeric: tabular-nums;
  color: rgba(255, 255, 255, .3);
  font-family: "SF Mono", "Fira Code", monospace;
  pointer-events: none;
}

.slide .subtitle { font-size: 1.1em; color: #666; }
.slide .author   { margin-top: .8em; color: #888; }
.slide .ref      { margin-top: .8em; font-size: .85em; color: #999; }
.slide .ref a    { color: #667eea; }

.slide .footnote {
  font-size: .75em;
  color: #999;
  margin-top: auto;
  padding-top: 1em;
}

@media print {
  @page {
    size: 1920px 1080px;
    margin: 0;
  }

  html { scroll-snap-type: none; background: white; }

  body {
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  .page {
    min-height: auto;
    padding: 0;
    scroll-snap-align: none;
  }

  .slide {
    width: 1920px;
    max-width: none;
    height: 1080px;
    aspect-ratio: auto;
    border-radius: 0;
    box-shadow: none;
    padding: 60px 80px 50px;
    break-after: page;
    page-break-after: always;
  }

  .page:last-child .slide {
    break-after: auto;
    page-break-after: auto;
  }

  .slide::before { border-radius: 0; }

  .pageno { display: none; }
}

@media (max-width: 800px) {
  .slide {
    width: 98vw;
    padding: 28px 32px 24px;
    border-radius: 8px;
  }

  .slide h1 { font-size: 1.6em; }
  .slide h2 { font-size: 1.2em; }
  .slide pre { font-size: .7em; padding: 12px 14px; }
}
</style>
</head>
<body>
{% for slide in slides %}
<section class="page">
  <div class="slide">
    {{ slide.content }}
  </div>
  <span class="pageno">{{ slide.number }}</span>
</section>
{% endfor %}
<script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
<script>
{% raw -%}
(function() {
  var preBlocks = document.querySelectorAll('.slide pre code');
  preBlocks.forEach(function(code) {
    var text = (code.textContent || '').trim();
    var firstLine = text.split('\n')[0].trim();
    var keywords = /^(graph|sequenceDiagram|classDiagram|stateDiagram|erDiagram|journey|gantt|pie|flowchart|quadrantChart|requirementDiagram|gitGraph|mindmap|timeline|sankey|xychart|block)\b/;
    if (keywords.test(firstLine)) {
      var pre = code.parentElement;
      var div = document.createElement('div');
      div.className = 'mermaid';
      div.textContent = text;
      pre.parentNode.replaceChild(div, pre);
    }
  });
  mermaid.initialize({ startOnLoad: true, theme: 'default', themeVariables: { fontSize: '16px' } });
})();
{%- endraw %}
</script>
</body>
</html>
